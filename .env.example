# ─────────────────────────────────────────────────────────────
# OpenAI — powers AI investment insights, image vision analysis,
# and the AI valuation report. Without a key, the app uses
# algorithmic fallbacks (the feature still works, with lower detail).
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
# Optional model overrides:
# OPENAI_VISION_MODEL=gpt-4o          # image analysis (vision-capable)
# OPENAI_REPORT_MODEL=gpt-4o-mini     # valuation report narrative

# ─────────────────────────────────────────────────────────────
# Google Maps — geocoding + Street View landmark matching (server side)
# and the interactive results map (browser side). Same key can be used
# for both; enable Geocoding API, Street View Static API, and Maps
# Embed API. Without these, the app falls back to OpenStreetMap embeds
# and coarse regional location.
# ─────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_server_key_here
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_browser_key_here

# ─────────────────────────────────────────────────────────────
# Real-estate data — comparable listings + market stats.
# Default provider: RentCast (https://rentcast.io). Without a key,
# the app generates synthetic comparables from regional price data.
# ─────────────────────────────────────────────────────────────
RENTCAST_API_KEY=your_rentcast_api_key_here
