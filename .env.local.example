# Copy this file to .env.local and fill in your keys.
# All keys are optional — the app uses graceful fallbacks without them.

# ─────────────────────────────────────────────────────────────
# DEMO MODE
# Set to true to use sample data (no API keys required).
# Remove or set to false once you have real keys.
# ─────────────────────────────────────────────────────────────
DEMO_MODE=true

# ─────────────────────────────────────────────────────────────
# OpenAI — vision analysis + AI valuation report
# https://platform.openai.com/api-keys
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Optional model overrides (defaults shown):
# OPENAI_VISION_MODEL=gpt-4o
# OPENAI_REPORT_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────────────────
# Google Maps
# Enable: Geocoding API, Street View Static API, Maps Embed API
# https://console.cloud.google.com/apis
# ─────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIza...
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...

# ─────────────────────────────────────────────────────────────
# RentCast — comparable listings + market data
# https://rentcast.io
# ─────────────────────────────────────────────────────────────
RENTCAST_API_KEY=...
